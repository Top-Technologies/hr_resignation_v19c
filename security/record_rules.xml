<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Employee can see their own resignation - cross company -->
        <record id="rule_hr_resignation_employee" model="ir.rule">
            <field name="name">Resignation: All users see all</field>
            <field name="model_id" ref="model_hr_resignation"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Manager can see their subordinates' resignations - cross company -->
        <record id="rule_hr_resignation_manager" model="ir.rule">
            <field name="name">Resignation: Manager see subordinates</field>
            <field name="model_id" ref="model_hr_resignation"/>
            <field name="domain_force">['|', ('employee_id.user_id', '=', user.id), ('employee_id.parent_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_resignation_manager'))]"/>
        </record>

        <!-- HR Manager see all - cross company -->
        <record id="rule_hr_resignation_all" model="ir.rule">
            <field name="name">Resignation: HR Manager see all</field>
            <field name="model_id" ref="model_hr_resignation"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hr.group_hr_manager'))]"/>
        </record>

        <!-- Clearance Rules - cross company -->
        <record id="rule_hr_clearance_employee" model="ir.rule">
            <field name="name">Clearance: All users see all</field>
            <field name="model_id" ref="model_hr_clearance"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="rule_hr_clearance_all" model="ir.rule">
            <field name="name">Clearance: HR Manager see all</field>
            <field name="model_id" ref="model_hr_clearance"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hr.group_hr_manager'))]"/>
        </record>

        <!-- Checklist Approver Rule - cross company -->
        <record id="rule_hr_clearance_checklist_approver" model="ir.rule">
            <field name="name">Clearance: Checklist Approver</field>
            <field name="model_id" ref="model_hr_clearance"/>
            <field name="domain_force">[('checklist_ids.responsible_user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>
    </data>
</odoo>
