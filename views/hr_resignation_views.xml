<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    <!-- Graph View -->
    <record id="view_hr_resignation_graph" model="ir.ui.view">
        <field name="name">hr.resignation.graph</field>
        <field name="model">hr.resignation</field>
        <field name="arch" type="xml">
            <graph string="Resignations" type="bar">
                <field name="employee_id"/>
                <field name="state" type="row"/>
            </graph>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_hr_resignation_pivot" model="ir.ui.view">
        <field name="name">hr.resignation.pivot</field>
        <field name="model">hr.resignation</field>
        <field name="arch" type="xml">
            <pivot string="Resignations">
                <field name="employee_id" type="row"/>
                <field name="state" type="col"/>
            </pivot>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_hr_resignation_tree" model="ir.ui.view">
        <field name="name">hr.resignation.tree</field>
        <field name="model">hr.resignation</field>
        <field name="arch" type="xml">
            <list string="Resignations" decoration-info="state == 'draft'" decoration-muted="state == 'cancel'" decoration-success="state == 'approved_hr'">
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="manager_id"/>
                <field name="resignation_date"/>
                <field name="last_working_day"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_hr_resignation_form" model="ir.ui.view">
            <field name="name">hr.resignation.form</field>
            <field name="model">hr.resignation</field>
            <field name="arch" type="xml">
                <form string="Resignation">
                    <header>
                        <button name="action_submit" string="Submit" type="object" class="oe_highlight" invisible="state != 'draft'"/>                        
                        <button name="action_approve_manager" string="Approve" type="object" class="oe_highlight" 
                                invisible="state != 'submitted' or not is_direct_manager"/>                       
                        <button name="action_approve_hr" string="Approve" type="object" class="oe_highlight" 
                                invisible="state != 'approved_manager' or not is_hr_manager"/>
                        <button name="action_reject" string="Reject" type="object" class="btn-danger" 
                                invisible="not can_reject"/>         
                        <button name="action_reset_to_draft" string="Reset to Draft" type="object" invisible="state not in ('rejected', 'cancel')"/>
                        <button name="action_cancel" string="Cancel" type="object" invisible="state in ('done', 'cancel', 'approved_hr')"/>                      
                        <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved_manager,approved_hr,done"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="employee_id" readonly="state != 'draft' or not is_hr_manager"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="is_direct_manager" invisible="1"/>
                                <field name="is_hr_manager" invisible="1"/>
                                <field name="can_reject" invisible="1"/>
                                
                                <field name="requested_by" string="Requested By" readonly="state != 'draft'" groups="hr.group_hr_user"/>
                                <field name="department_id"/>
                                <field name="job_id"/>
                                <field name="manager_id"/>
                            </group>
                            <group>
                                <field name="resignation_date" readonly="state != 'draft'"/>
                                <field name="last_working_day" readonly="state != 'draft'"/>
                                <field name="notice_period"/>
                            </group>
                        </group>
                        <group>
                            <field name="clearance_business_unit_ids" widget="many2many_tags" options="{'no_create': True}" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="reason" readonly="state != 'draft'"/>
                            <field name="remarks" readonly="state != 'draft'"/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

    <!-- Action -->
    <record id="action_hr_resignation" model="ir.actions.act_window">
        <field name="name">Resignations</field>
        <field name="res_model">hr.resignation</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Resignation Request
            </p>
        </field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_hr_resignation_root" name="Resignations" parent="hr.menu_hr_root" sequence="20"/>
    <menuitem id="menu_hr_resignation_request" name="Resignation Requests" parent="menu_hr_resignation_root" action="action_hr_resignation" sequence="1"/>
    </data>
</odoo>