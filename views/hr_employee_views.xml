<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    <record id="view_employee_form_resignation_inherit" model="ir.ui.view">
        <field name="name">hr.employee.form.resignation.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_view_resignations"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-sign-out"
                        invisible="resignation_count == 0">
                    <field name="resignation_count" widget="statinfo" string="Resignations"/>
                </button>
                <button name="action_view_clearances"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-check-square-o"
                        invisible="clearance_count == 0">
                    <field name="clearance_count" widget="statinfo" string="Clearances"/>
                </button>
            </div>
        </field>
    </record>
    </data>
</odoo>
